# Copy to .env. Calendar feeds are configured in ics.json (see ics.json.example).
# Optional: path to feeds file (default: ics.json in the backend process working directory).
# FEEDS_FILE=ics.json

PORT=4000
TIMEZONE=Europe/Amsterdam
CACHE_TTL_MINUTES=30
FETCH_TIMEOUT_SECONDS=10
FAILURE_REFRESH_COOLDOWN_MINUTES=10
STATIC_DIR=/opt/calendar-kiosk/frontend/dist
